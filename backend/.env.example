# UniVault Backend Environment Variables
# Copy this file to .env and fill in your values

# Application
APP_NAME=UniVault
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://univault:univault@localhost:5432/univault

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["*"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Scraping
SCRAPER_TIMEOUT=15
